<Window x:Class="RingKnifeDetector.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:RingKnifeDetector.Views"
        mc:Ignorable="d"
        Title="环刀法压实度检测工具" Height="780" Width="1400"
        Icon="pack://application:,,,/Resources/scetia.ico"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">
    <Window.Resources>
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Width" Value="100"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="Background" Value="#FF007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="ActionGreen" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="8,0"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="#FF2E7D32"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style x:Key="ActionBlue" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="8,0"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="#FF007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style x:Key="ActionRed" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="8,0"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="#FFC62828"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style x:Key="CellLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="4,2"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="CellInput" TargetType="TextBox">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="2,2"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderBrush" Value="#FFCCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 导航栏 -->
        <Border Grid.Row="0" Background="#FF2D2D30" Padding="10,5">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="btnTaskList" Content="任务列表" Style="{StaticResource NavButton}" Click="BtnTaskList_Click"/>
                <Button x:Name="btnRecord" Content="记录填写" Style="{StaticResource NavButton}" Click="BtnRecord_Click"/>
                <Button x:Name="btnSettings" Content="设置" Style="{StaticResource NavButton}" Click="BtnSettings_Click"/>
            </StackPanel>
        </Border>

        <!-- 主内容区域 -->
        <Grid Grid.Row="1" Margin="10">

            <!-- ==================== 任务列表视图 ==================== -->
            <Grid x:Name="taskListView" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="任务列表" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="txtSearchKeyword" Grid.Column="0" Height="28" VerticalContentAlignment="Center">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Foreground" Value="Gray"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <Button Grid.Column="1" Content="搜索" Width="80" Height="28" Margin="10,0,0,0"
                            Click="BtnSearch_Click" Style="{StaticResource ActionBlue}"/>
                </Grid>

                <DataGrid Grid.Row="2" x:Name="dgTasks"
                          AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          MouseDoubleClick="DgTasks_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="委托编号" Binding="{Binding TestingOrderNo}" Width="130"/>
                        <DataGridTextColumn Header="任务编号" Binding="{Binding TaskNo}" Width="130"/>
                        <DataGridTextColumn Header="样品名称" Binding="{Binding SampleName}" Width="130"/>
                        <DataGridTextColumn Header="工程名称" Binding="{Binding ProjectName}" Width="180"/>
                        <DataGridTextColumn Header="工程部位" Binding="{Binding PrincipalPart}" Width="130"/>
                        <DataGridTextColumn Header="状态" Binding="{Binding StatusName}" Width="100"/>
                        <DataGridTextColumn Header="剩余天数" Binding="{Binding RemainDays}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- 分页控件 -->
                <Grid Grid.Row="3" Margin="0,8,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="btnPrevPage" Content="上一页" Width="70" Height="26" Margin="4,0"
                                Click="BtnPrevPage_Click" IsEnabled="False" Style="{StaticResource ActionBlue}"/>
                        <TextBlock x:Name="txtPageInfo" VerticalAlignment="Center" Margin="12,0" FontSize="12"/>
                        <Button x:Name="btnNextPage" Content="下一页" Width="70" Height="26" Margin="4,0"
                                Click="BtnNextPage_Click" IsEnabled="False" Style="{StaticResource ActionBlue}"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- ==================== 记录填写视图 ==================== -->
            <ScrollViewer x:Name="recordView" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,0,0,10">

                    <!-- 报告抬头信息 -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="检测性质：" Style="{StaticResource CellLabel}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtTestNature" Style="{StaticResource CellInput}"/>

                        <TextBlock Grid.Row="0" Grid.Column="2" Text="委托编号：" Style="{StaticResource CellLabel}"/>
                        <Grid Grid.Row="0" Grid.Column="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" x:Name="txtEntrustNo" Style="{StaticResource CellInput}"/>
                            <Button Grid.Column="1" Content="LIMIS" Margin="4,0,0,0" Padding="8,2"
                                    Click="BtnFetchFromLimis_Click" Style="{StaticResource ActionBlue}" Height="24"/>
                        </Grid>

                        <TextBlock Grid.Row="1" Grid.Column="2" Text="报告编号：" Style="{StaticResource CellLabel}"/>
                        <TextBox Grid.Row="1" Grid.Column="3" x:Name="txtReportNo" Style="{StaticResource CellInput}"/>
                    </Grid>

                    <!-- 工程信息 -->
                    <GroupBox Header="工程信息" Margin="0,0,0,8" Padding="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="委托单位：" Style="{StaticResource CellLabel}"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtEntrustUnit" Style="{StaticResource CellInput}"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="联系方式：" Style="{StaticResource CellLabel}"/>
                            <TextBox Grid.Row="0" Grid.Column="3" x:Name="txtContact" Style="{StaticResource CellInput}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="工程名称：" Style="{StaticResource CellLabel}"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtProjectName" Style="{StaticResource CellInput}"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="单位地址：" Style="{StaticResource CellLabel}"/>
                            <TextBox Grid.Row="1" Grid.Column="3" x:Name="txtUnitAddress" Style="{StaticResource CellInput}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="监理单位：" Style="{StaticResource CellLabel}"/>
                            <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtSupervisionUnit" Style="{StaticResource CellInput}"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="施工单位：" Style="{StaticResource CellLabel}"/>
                            <TextBox Grid.Row="2" Grid.Column="3" x:Name="txtConstructionUnit" Style="{StaticResource CellInput}"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="工程地址：" Style="{StaticResource CellLabel}"/>
                            <TextBox Grid.Row="3" Grid.Column="1" x:Name="txtProjectAddress" Style="{StaticResource CellInput}"/>
                            <TextBlock Grid.Row="3" Grid.Column="2" Text="委托日期：" Style="{StaticResource CellLabel}"/>
                            <DatePicker Grid.Row="3" Grid.Column="3" x:Name="dpEntrustDate" Margin="2,2" FontSize="12"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="工程部位：" Style="{StaticResource CellLabel}"/>
                            <TextBox Grid.Row="4" Grid.Column="1" x:Name="txtProjectSection" Style="{StaticResource CellInput}"/>
                            <TextBlock Grid.Row="4" Grid.Column="2" Text="报告日期：" Style="{StaticResource CellLabel}"/>
                            <DatePicker Grid.Row="4" Grid.Column="3" x:Name="dpReportDate" Margin="2,2" FontSize="12"/>
                        </Grid>
                    </GroupBox>

                    <!-- 检测参数 -->
                    <GroupBox Header="检测参数" Margin="0,0,0,8" Padding="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="样品名称：" Style="{StaticResource CellLabel}"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtSampleName" Text="回填土" Style="{StaticResource CellInput}"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="材料种类：" Style="{StaticResource CellLabel}"/>
                            <TextBox Grid.Row="0" Grid.Column="3" x:Name="txtMaterialType" Style="{StaticResource CellInput}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="环刀规格：" Style="{StaticResource CellLabel}"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtRingSpec" Text="200cm³" Style="{StaticResource CellInput}"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="夯实方式：" Style="{StaticResource CellLabel}"/>
                            <TextBox Grid.Row="1" Grid.Column="3" x:Name="txtCompactionMethod" Style="{StaticResource CellInput}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="设计要求：" Style="{StaticResource CellLabel}"/>
                            <Grid Grid.Row="2" Grid.Column="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="≥" VerticalAlignment="Center" FontSize="14" FontWeight="Bold" Margin="4,0,0,0"/>
                                <TextBox Grid.Column="1" x:Name="txtDesignRequirement" Style="{StaticResource CellInput}"/>
                            </Grid>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="最大干密度/(g/cm³)：" Style="{StaticResource CellLabel}"/>
                            <TextBox Grid.Row="2" Grid.Column="3" x:Name="txtMaxDryDensity" Style="{StaticResource CellInput}"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="取样部位：" Style="{StaticResource CellLabel}"/>
                            <TextBox Grid.Row="3" Grid.Column="1" x:Name="txtTestLocation" Style="{StaticResource CellInput}"/>
                            <TextBlock Grid.Row="3" Grid.Column="2" Text="最优含水率/%：" Style="{StaticResource CellLabel}"/>
                            <TextBox Grid.Row="3" Grid.Column="3" x:Name="txtOptimalMoisture" Style="{StaticResource CellInput}"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="检测依据：" Style="{StaticResource CellLabel}"/>
                            <TextBox Grid.Row="4" Grid.Column="1" x:Name="txtTestBasis" Text="JTG 3450-2019" Style="{StaticResource CellInput}"/>
                            <TextBlock Grid.Row="4" Grid.Column="2" Text="判定依据：" Style="{StaticResource CellLabel}"/>
                            <TextBox Grid.Row="4" Grid.Column="3" x:Name="txtJudgeBasis" Text="JTG 3450-2019" Style="{StaticResource CellInput}"/>
                        </Grid>
                    </GroupBox>

                    <!-- 原始记录备注（LIMIS） -->
                    <GroupBox Header="原始记录备注（LIMIS）" Margin="0,0,0,8" Padding="6">
                        <TextBox x:Name="txtLimisRemark" Style="{StaticResource CellInput}" MinHeight="48"
                                 TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                    </GroupBox>

                    <!-- 原始记录 -->
                    <GroupBox Margin="0,0,0,8" Padding="6">
                        <GroupBox.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="原始记录" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                <ComboBox x:Name="cmbRecordTemplate" Width="220" Margin="16,0,0,0" SelectedIndex="0"
                                          SelectionChanged="CmbRecordTemplate_Changed">
                                    <ComboBoxItem Content="环刀（2个1组 · 2环刀4铝盒）" Tag="group2"/>
                                    <ComboBoxItem Content="环刀（3个1组 · 3环刀6铝盒）" Tag="group3"/>
                                </ComboBox>
                                <RadioButton Content="压实度%" GroupName="ResultType" Margin="16,0,0,0" VerticalAlignment="Center"
                                             x:Name="rbCompactionPercent" Checked="ResultType_Changed"/>
                                <RadioButton Content="压实系数" GroupName="ResultType" Margin="8,0,0,0" VerticalAlignment="Center"
                                             x:Name="rbCompactionCoeff" IsChecked="True" Checked="ResultType_Changed"/>
                                <Button Content="+ 添加测点" Margin="16,0,0,0" Padding="10,2" Click="BtnAddRow_Click"
                                        Style="{StaticResource ActionBlue}" Height="24"/>
                            </StackPanel>
                        </GroupBox.Header>

                        <views:RecordTableControl x:Name="recordTable"/>
                    </GroupBox>

                    <!-- 检测结果 -->
                    <GroupBox Header="检测结果" Margin="0,0,0,8" Padding="6">
                        <StackPanel>
                            <DataGrid x:Name="dgResults" AutoGenerateColumns="False" CanUserAddRows="False"
                                      CanUserDeleteRows="False" GridLinesVisibility="All" HeadersVisibility="Column"
                                      IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="样品编号" Binding="{Binding SampleNo}" Width="150" MinWidth="130"/>
                                    <DataGridTextColumn Header="取样点标高/(mm)" Binding="{Binding Elevation}" Width="100"/>
                                    <DataGridTextColumn Header="取样点厚度/(mm)" Binding="{Binding Thickness}" Width="100"/>
                                    <DataGridTextColumn Header="取样日期" Binding="{Binding SamplingDate}" Width="100"/>
                                    <DataGridTextColumn Header="检测日期" Binding="{Binding TestDate}" Width="100"/>
                                    <DataGridTextColumn Header="湿密度/(g/cm³)" Binding="{Binding AvgWetDensity}" Width="100"/>
                                    <DataGridTextColumn Header="含水率/%" Binding="{Binding AvgMoisture}" Width="80"/>
                                    <DataGridTextColumn Header="干密度/(g/cm³)" Binding="{Binding AvgDryDensity}" Width="100"/>
                                    <DataGridTextColumn Header="压实系数" Binding="{Binding CompactionCoeff}" Width="80"/>
                                    <DataGridTextColumn Header="结论" Binding="{Binding Conclusion}" Width="120"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="检测结论：" FontWeight="Bold" VerticalAlignment="Top" Margin="0,4,0,0"/>
                                <TextBox Grid.Column="1" x:Name="txtConclusion" IsReadOnly="True" Background="#FFF5F5F5"
                                         BorderBrush="#FFCCCCCC" BorderThickness="1" Padding="4,2" Margin="4,0,0,0"/>
                            </Grid>
                            <Grid Margin="0,8,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="报告备注：" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBox Grid.Row="1" x:Name="txtReportRemarks" Style="{StaticResource CellInput}" MinHeight="120"
                                         TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                            </Grid>
                        </StackPanel>
                    </GroupBox>

                    <!-- 操作栏 -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                        <Button Content="计算" Style="{StaticResource ActionGreen}" Click="BtnCalculate_Click"/>
                        <Button Content="导出 Excel" Style="{StaticResource ActionBlue}" Click="BtnExportExcel_Click"/>
                        <Button Content="导出 Word" Style="{StaticResource ActionBlue}" Click="BtnExportWord_Click"/>
                        <Button Content="保存草稿" Style="{StaticResource ActionBlue}" Click="BtnSaveDraft_Click"/>
                        <Button Content="清空" Style="{StaticResource ActionRed}" Click="BtnClear_Click"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- ==================== 设置视图 ==================== -->
            <Grid x:Name="settingsView" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="设置" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                <GroupBox Grid.Row="1" Header="LIMIS系统配置" Margin="0,0,0,10" Padding="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="服务器地址：" Style="{StaticResource CellLabel}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtBaseUrl" Style="{StaticResource CellInput}" Text="http://10.1.228.22"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="用户名：" Style="{StaticResource CellLabel}"/>
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtUsername" Style="{StaticResource CellInput}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="密码：" Style="{StaticResource CellLabel}"/>
                        <PasswordBox Grid.Row="2" Grid.Column="1" x:Name="txtPassword" Margin="2,2" Padding="4,2"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="主检姓名：" Style="{StaticResource CellLabel}"/>
                        <TextBox Grid.Row="3" Grid.Column="1" x:Name="txtRealName" Style="{StaticResource CellInput}" IsReadOnly="True" Background="#FFF5F5F5"/>

                        <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="2,8,0,0">
                            <Button Content="测试登录" Width="100" Height="28" Click="BtnTestLogin_Click" Style="{StaticResource ActionBlue}"/>
                            <Button Content="保存设置" Width="100" Height="28" Margin="8,0,0,0" Click="BtnSaveSettings_Click" Style="{StaticResource ActionGreen}"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>
            </Grid>
        </Grid>

        <!-- 状态栏 -->
        <Border Grid.Row="2" Background="#FF007ACC" Padding="10,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="txtStatus" Text="就绪" Foreground="White"/>
                <TextBlock Grid.Column="1" x:Name="txtUserInfo" Foreground="White"/>
            </Grid>
        </Border>
    </Grid>
</Window>